{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Overflow",
  "version": "2.1.0",
  "identifier": "com.dajbelshaw.overflow",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Overflow",
        "width": 1100,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http: https: 'unsafe-inline' data: blob:; media-src 'self' http: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Cover Flow music player for Plex",
    "macOS": {
      "signingIdentity": null
    }
  }
}
